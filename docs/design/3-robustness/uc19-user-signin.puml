@startuml uc19-user-signin
!theme plain
skinparam linetype ortho

actor "Guest" as guest
boundary "SigninPage (/signin/)" as signin
control "AuthActions" as actions
control "LoginUseCase" as uc
entity "LocalStorage" as storage
boundary "VaultPage (/vault/)" as vault

guest -> signin : Input Credentials
signin -> actions : signin(password)
actions -> uc : execute({password})
uc -> storage : setItem("session_token", token)
actions -> vault : Redirect to /vault/
@enduml
