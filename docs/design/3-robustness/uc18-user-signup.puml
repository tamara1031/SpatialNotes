@startuml uc18-user-signup
!theme plain
skinparam linetype ortho

actor "Guest" as guest
boundary "SignupPage (/signup/)" as signup
control "AuthActions" as actions
control "RegisterVaultUseCase" as uc
entity "LocalStorage" as storage
boundary "NotesPage (/notes/)" as notes

guest -> signup : Input Credentials
signup -> actions : signup(email, pw)
actions -> uc : execute({email, pw})
uc -> storage : setItem("session_token", token)
actions -> notes : Redirect to /notes/
@enduml
