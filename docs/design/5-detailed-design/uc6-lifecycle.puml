@startuml uc6-node-lifecycle-sequence
!theme plain
skinparam backgroundColor white

participant "Sidebar" as UI
participant "RenameNodeUseCase" as UC
participant "Node" as Domain
participant "DomainEventBus" as Bus
participant "SyncService" as Sync
participant "UpdateNodeCommand" as Cmd
participant "IStore (YjsAdapter)" as Store
participant "SubtreeDeletionService" as Service

UI -> UC : renameNode(nodeId, newName)
activate UC

UC -> Domain : rename(newName)
UC -> Bus : publish(NodeRenamed)
activate Bus

Bus -> Sync : handleNodeRenamed(event)
activate Sync

Sync -> Cmd : new UpdateNodeCommand(store, event.payload)
Sync -> Cmd : execute()
Cmd -> Store : set(id, record)
deactivate Sync
deactivate Bus

Store -> UI : notify subscribers
deactivate UC

UI -> UC : deleteNode(nodeId)
activate UC
UC -> Service : markSubtreeAsDeleted(nodeId)
activate Service
Service -> Domain : markDeleted()
deactivate Service
UC -> Bus : publish(NodeDeleted)
deactivate UC

@enduml

@enduml
