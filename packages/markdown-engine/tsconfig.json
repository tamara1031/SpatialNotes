{
	"compilerOptions": {
		"target": "ESNext",
		"module": "CommonJS",
		"declaration": true,
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "node",
		"baseUrl": ".",
		"jsx": "react-jsx",
		"paths": {
			"engine-core": ["../engine-core/src/index.ts"]
		}
	},
	"include": ["src/**/*"]
}
