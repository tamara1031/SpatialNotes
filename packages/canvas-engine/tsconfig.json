{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"declaration": true,
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "Bundler",
		"rootDir": ".",
		"baseUrl": ".",
		"jsx": "react-jsx"
	},
	"include": ["src/**/*", "tests/**/*"]
}
