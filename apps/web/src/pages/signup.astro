---
import Shell from "../layouts/Shell.astro";
import AuthModalHeader from "../components/auth/AuthModalHeader.astro";
import { SignupForm } from "../components/auth/SignupForm";
---

<Shell title="Sign Up - SpatialNotes">
    <div class="auth-page">
        <div class="auth-card glass-panel">
            <AuthModalHeader mode="signup" />

            <SignupForm client:only="react" redirectPath="/notes/" />

            <div class="auth-footer">
                <p>Already have a vault? <a href="/signin/">Sign in</a></p>
            </div>
        </div>
        <a href="/" class="back-link">← Back to home</a>
    </div>
</Shell>

<style>
    .auth-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: var(--surface);
    }

    .auth-container {
        width: 100%;
        max-width: 450px;
        background: var(--surface-raised);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        padding: 3rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .back-link {
        margin-top: 2rem;
        color: var(--text-secondary);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--text-primary);
    }
</style>

<script>
    import { enforceAuthStatus } from "../utils/AuthGuard";
    enforceAuthStatus("public");
</script>
